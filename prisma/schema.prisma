generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "commonjs"
}

datasource db {
  provider = "postgresql"
}

enum ChampionshipFormat {
  LEAGUE
  GROUPS
  KNOCKOUT
}

enum ChampionshipStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  FINISHED
}

enum PlayerPosition {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  POSTPONED
  CANCELLED
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @db.VarChar(120)
  email         String         @unique @db.VarChar(255)
  passwordHash  String         @map("password_hash") @db.VarChar(255)
  avatarUrl     String?        @map("avatar_url")
  championships Championship[]
  teams         Team[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model Championship {
  id           String             @id @default(uuid()) @db.Uuid
  ownerId      String             @map("owner_id") @db.Uuid
  name         String             @db.VarChar(120)
  season       String             @db.VarChar(30)
  description  String?            @db.Text
  maxTeams     Int                @map("max_teams")
  format       ChampionshipFormat
  status       ChampionshipStatus @default(DRAFT)
  startDate    DateTime           @map("start_date") @db.Date
  endDate      DateTime           @map("end_date") @db.Date
  owner        User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  teams        ChampionshipTeam[]
  matches      Match[]
  standings    Standing[]
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@unique([ownerId, name, season])
  @@index([ownerId])
  @@map("championships")
}

model Team {
  id            String             @id @default(uuid()) @db.Uuid
  ownerId       String             @map("owner_id") @db.Uuid
  name          String             @db.VarChar(120)
  city          String             @db.VarChar(100)
  state         String             @db.Char(2)
  crestUrl      String?            @map("crest_url")
  primaryColor  String             @map("primary_color") @db.VarChar(7)
  secondaryColor String            @map("secondary_color") @db.VarChar(7)
  coach         String             @db.VarChar(120)
  owner          User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  championships ChampionshipTeam[]
  players       Player[]
  homeMatches   Match[]            @relation("HomeTeam")
  awayMatches   Match[]            @relation("AwayTeam")
  standings     Standing[]
  goals         Goal[]
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@index([name])
  @@index([ownerId])
  @@map("teams")
}

model ChampionshipTeam {
  championshipId String       @map("championship_id") @db.Uuid
  teamId         String       @map("team_id") @db.Uuid
  groupName      String?      @map("group_name") @db.VarChar(10)
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  team           Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@id([championshipId, teamId])
  @@index([teamId])
  @@map("championship_teams")
}

model Player {
  id        String         @id @default(uuid()) @db.Uuid
  teamId    String         @map("team_id") @db.Uuid
  name      String         @db.VarChar(120)
  number    Int
  position  PlayerPosition
  birthDate DateTime       @map("birth_date") @db.Date
  photoUrl  String?        @map("photo_url")
  isCaptain Boolean        @default(false) @map("is_captain")
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  goals     Goal[]
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@unique([teamId, number])
  @@index([teamId])
  @@index([name])
  @@map("players")
}

model Match {
  id             String      @id @default(uuid()) @db.Uuid
  championshipId String      @map("championship_id") @db.Uuid
  homeTeamId     String      @map("home_team_id") @db.Uuid
  awayTeamId     String      @map("away_team_id") @db.Uuid
  round          Int
  groupName      String?     @map("group_name") @db.VarChar(10)
  scheduledAt    DateTime    @map("scheduled_at")
  venue          String      @db.VarChar(160)
  homeScore      Int?        @map("home_score")
  awayScore      Int?        @map("away_score")
  status         MatchStatus @default(SCHEDULED)
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  homeTeam       Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam       Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  goals          Goal[]
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([championshipId, scheduledAt])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@map("matches")
}

model Standing {
  id             String       @id @default(uuid()) @db.Uuid
  championshipId String       @map("championship_id") @db.Uuid
  teamId         String       @map("team_id") @db.Uuid
  position       Int
  played         Int          @default(0)
  wins           Int          @default(0)
  draws          Int          @default(0)
  losses         Int          @default(0)
  goalsFor       Int          @default(0) @map("goals_for")
  goalsAgainst   Int          @default(0) @map("goals_against")
  goalDifference Int          @default(0) @map("goal_difference")
  points         Int          @default(0)
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  team           Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([championshipId, teamId])
  @@index([championshipId, position])
  @@map("standings")
}

model Goal {
  id        String   @id @default(uuid()) @db.Uuid
  matchId   String   @map("match_id") @db.Uuid
  playerId  String   @map("player_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  minute    Int
  isOwnGoal Boolean  @default(false) @map("is_own_goal")
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id])
  team      Team     @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@index([matchId])
  @@index([playerId])
  @@map("goals")
}
